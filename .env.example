# ============================================================
# Epic Kiosk 环境变量配置文件
# ============================================================
# 使用方式：
#   cp .env.example .env
#   nano .env
#
# 不要把真实 .env 提交到 Git。
# ============================================================

# ============================================================
# OpenAI-compatible API Provider（二选一或自定义）
# ============================================================

# 推荐生产配置：NVIDIA
# API_PROVIDER=nvidia
# API_BASE_URL=https://integrate.api.nvidia.com/v1
# API_KEY=<your-nvidia-api-key>
# CAPTCHA_MODEL=meta/llama-4-maverick-17b-128e-instruct
# CAPTCHA_MODEL_FALLBACK=meta/llama-4-maverick-17b-128e-instruct

# 兼容配置：SiliconFlow（一键部署脚本默认按此类配置引导）
API_PROVIDER=siliconflow
API_BASE_URL=https://api.siliconflow.cn/v1
API_KEY=
CAPTCHA_MODEL=Qwen/Qwen3-VL-32B-Instruct
CAPTCHA_MODEL_FALLBACK=Qwen/Qwen3-VL-30B-A3B-Instruct

# Web 与 Worker 内部接口共享密钥（必须使用随机值）
# 生成命令: openssl rand -hex 32
INTERNAL_API_TOKEN=

# 验证码失败恢复策略
CAPTCHA_FAILURE_MAX_RETRIES=2
CAPTCHA_FAILURE_RETRY_DELAY_SECONDS=900
NETWORK_FAILURE_MAX_RETRIES=2
NETWORK_FAILURE_RETRY_DELAY_SECONDS=600
WARP_RESTART_COOLDOWN_SECONDS=300
TASK_SPACING_SECONDS=5
TASK_TIMEOUT_SECONDS=600
TASK_LOCK_SECONDS=86400
COOKIE_INVALID_MAX_RETRIES=1

# 仅正式 Web 服务应启用每日自动调度；临时预览容器不要启用。
ENABLE_APSCHEDULER=true
DAILY_SCHEDULE_LOCK_SECONDS=86400

# hCaptcha 等待与模型请求超时
HCAPTCHA_EXECUTION_TIMEOUT=240
HCAPTCHA_RESPONSE_TIMEOUT=120
HCAPTCHA_PAYLOAD_TIMEOUT=90
HCAPTCHA_FRAME_TIMEOUT=20
HCAPTCHA_SOLVE_MAX_ATTEMPTS=4
CAPTCHA_API_TIMEOUT=60
CAPTCHA_API_RETRIES=1
CAPTCHA_RESPONSE_MAX_TOKENS=1200

# 可选：外部验证码服务商兜底。默认关闭。
CAPTCHA_PROVIDER=none
CAPTCHA_PROVIDER_API_KEY=
CAPTCHA_PROVIDER_SITE_KEY=91e4137f-95af-4bc9-97af-cdcedce21c8c
CAPTCHA_PROVIDER_TIMEOUT=180
CAPTCHA_PROVIDER_POLL_INTERVAL=5
